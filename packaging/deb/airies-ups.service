[Unit]
Description=Airies UPS Monitor
Documentation=https://git.airies.net/vifair22/airies-ups-c
After=network.target

[Service]
Type=simple
User=airies-ups
Group=airies-ups
ExecStart=/usr/bin/airies-upsd
WorkingDirectory=/var/lib/airies-ups
Environment=AIRIES_UPS_CONFIG_PATH=/var/lib/airies-ups/config.yaml
Restart=on-failure
RestartSec=5
RuntimeDirectory=airies-ups
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
